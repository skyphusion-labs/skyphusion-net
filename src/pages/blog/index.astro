---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogJsonLd } from '../../lib/seo';

const site = Astro.site?.href ?? 'https://skyphusion.net';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout
  title="Blog, skyphusion.net"
  description="All posts on skyphusion.net"
  jsonLd={blogJsonLd(site)}
>
  <h1>Blog</h1>
  <p class="browse"><a href="/blog/tags/">Browse by tag</a></p>
  {posts.length === 0 ? (
    <p class="muted">No posts yet.</p>
  ) : (
    <ul class="post-list">
      {posts.map(post => (
        <li>
          <div class="post-header">
            <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </div>
          <p class="excerpt">{post.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .browse {
    margin-top: -0.5rem;
    font-size: 0.875rem;
  }
  .post-list {
    list-style: none;
    padding: 0;
  }
  .post-list li {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .post-list li:last-child { border-bottom: none; }
  .post-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .post-title { font-weight: 600; }
  .post-list time {
    color: var(--muted);
    font-size: 0.8125rem;
    white-space: nowrap;
  }
  .excerpt {
    margin: 0.375rem 0 0 0;
    color: var(--muted);
    font-size: 0.9375rem;
  }
  .muted { color: var(--muted); }
</style>
