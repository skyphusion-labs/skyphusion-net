---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { webSiteJsonLd } from '../lib/seo';

const site = Astro.site?.href ?? 'https://skyphusion.net';

// Featured post slug. Set to null to hide the Featured section entirely.
const FEATURED_SLUG: string | null = 'vivijure-talking-character';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = FEATURED_SLUG
  ? allPosts.find((p) => p.id === FEATURED_SLUG)
  : undefined;

// Hide the featured post from the recent list so it doesn't appear twice.
const posts = allPosts
  .filter((p) => p.id !== FEATURED_SLUG)
  .slice(0, 10);
---
<BaseLayout
  title="Conrad Rockenhaus: Cloudflare, AI infrastructure, and self-hosting"
  description="Engineering notes on building and running multimodal AI, email, and open source systems on Cloudflare Workers, self-hosted end to end."
  jsonLd={webSiteJsonLd(site)}
>
  <h1>Home Page of Conrad Rockenhaus</h1>
  <p>
    Engineering blog and project hub for <a href="https://skyphusion.org">Skyphusion Labs</a>.
    Notes on Cloudflare, AI infrastructure, and open source systems we build and run.
    Our flagship is <a href="https://vivijure.skyphusion.org/welcome">Vivijure</a>, a free AGPL-3.0 AI film studio you own outright.
  </p>
  <p class="identity-links">
    <a href="https://github.com/skyphusion">GitHub</a>
    <span class="sep">/</span>
    <a href="https://github.skyphusion.net">GitHub page</a>
    <span class="sep">/</span>
    <a href="https://github.skyphusion.org">Labs GitHub page</a>
    <span class="sep">/</span>
    <a href="https://github.com/skyphusion-labs">github.com/skyphusion-labs</a>
    <span class="sep">/</span>
    <a href="https://x.com/skyphusion">X</a>
  </p>

  <section class="projects-teaser">
    <h2>Open source</h2>
    <p>
      <a href="/projects/">View all projects</a>
      <span class="sep">/</span>
      multimodal AI, film studio, Discord roadies, OSINT attribution, federated MUD, searchable email on Workers.
    </p>
  </section>

  {featured && (
    <section class="featured">
      <h2>Featured</h2>
      <p class="featured-item">
        <a href={`/blog/${featured.id}/`}>{featured.data.title}</a>
      </p>
      <p class="featured-summary">
        Vivijure Speaks: a talking character rendered through the studio UI, lip-synced on a self-hosted GPU module, with three orchestration bugs fixed before any user hit them.
      </p>
    </section>
  )}

  <h2>Recent posts</h2>
  {posts.length === 0 ? (
    <p class="muted">No other posts yet.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .projects-teaser {
    margin-bottom: 2rem;
  }
  .identity-links {
    margin: 0.75rem 0 0 0;
    font-size: 0.875rem;
    color: var(--muted);
  }
  .projects-teaser p {
    margin: 0.5rem 0 0 0;
    color: var(--muted);
    font-size: 0.9375rem;
  }
  .sep { color: var(--border); margin: 0 0.5rem; }
  .featured {
    margin-bottom: 2rem;
  }
  .featured-item {
    margin: 0.5rem 0 0.25rem 0;
    font-weight: 600;
  }
  .featured-summary {
    margin: 0;
    color: var(--muted);
    font-size: 0.9375rem;
  }
  .post-list {
    list-style: none;
    padding: 0;
  }
  .post-list li {
    margin-bottom: 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .post-list time {
    color: var(--muted);
    font-size: 0.8125rem;
    white-space: nowrap;
  }
  .muted { color: var(--muted); }
</style>
