---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Featured post slug. Set to null to hide the Featured section entirely.
const FEATURED_SLUG: string | null = 'vivijure';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = FEATURED_SLUG
  ? allPosts.find((p) => p.id === FEATURED_SLUG)
  : undefined;

// Hide the featured post from the recent list so it doesn't appear twice.
const posts = allPosts
  .filter((p) => p.id !== FEATURED_SLUG)
  .slice(0, 10);
---
<BaseLayout title="skyphusion.net" description="Home page of Conrad Rockenhaus">
  <h1>Home Page of Conrad Rockenhaus</h1>
  <p>Personal site. Notes on technology, infrastructure, and occasional findings from other domains.</p>

  {featured && (
    <section class="featured">
      <h2>Featured</h2>
      <p class="featured-item">
        <a href={`/blog/${featured.id}`}>{featured.data.title}</a>
      </p>
      <p class="featured-summary">
        How an always-on Cloudflare Worker and a scale-to-zero RunPod GPU backend split an AI film/video pipeline so it pays nothing while idle.
      </p>
    </section>
  )}

  <h2>Recent posts</h2>
  {posts.length === 0 ? (
    <p class="muted">No other posts yet.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .featured {
    margin-bottom: 2rem;
  }
  .featured-item {
    margin: 0.5rem 0 0.25rem 0;
    font-weight: 600;
  }
  .featured-summary {
    margin: 0;
    color: var(--muted);
    font-size: 0.9375rem;
  }
  .post-list {
    list-style: none;
    padding: 0;
  }
  .post-list li {
    margin-bottom: 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .post-list time {
    color: var(--muted);
    font-size: 0.8125rem;
    white-space: nowrap;
  }
  .muted { color: var(--muted); }
</style>
