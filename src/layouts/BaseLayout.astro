---
import {
  absoluteUrl,
  canonicalUrl,
  DEFAULT_OG_IMAGE,
  DEFAULT_OG_IMAGE_ALT,
  DEFAULT_OG_IMAGE_HEIGHT,
  DEFAULT_OG_IMAGE_WIDTH,
  SITE_NAME,
  SOCIAL_PROFILES,
  X_USERNAME,
} from '../lib/seo';

interface ArticleMeta {
  publishedTime: Date;
  modifiedTime?: Date;
  tags?: string[];
}

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  article?: ArticleMeta;
}

const {
  title,
  description = 'skyphusion.net',
  ogType = 'website',
  ogImage,
  ogImageWidth,
  ogImageHeight,
  jsonLd,
  article,
} = Astro.props;

const site = Astro.site?.href ?? 'https://skyphusion.net';
const canonical = canonicalUrl(Astro.url.pathname, site);
const image = absoluteUrl(ogImage ?? DEFAULT_OG_IMAGE, site);
const imageWidth = ogImageWidth ?? (!ogImage ? DEFAULT_OG_IMAGE_WIDTH : undefined);
const imageHeight = ogImageHeight ?? (!ogImage ? DEFAULT_OG_IMAGE_HEIGHT : undefined);
const imageAlt = ogImage ? description : DEFAULT_OG_IMAGE_ALT;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" title="skyphusion.net" href="/rss.xml" />
  {SOCIAL_PROFILES.map((profile) => (
    <link rel="me" href={profile} />
  ))}
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={image} />
  {imageWidth && <meta property="og:image:width" content={String(imageWidth)} />}
  {imageHeight && <meta property="og:image:height" content={String(imageHeight)} />}
  <meta property="og:image:alt" content={imageAlt} />

  {article && (
    <>
      <meta property="article:published_time" content={article.publishedTime.toISOString()} />
      {article.modifiedTime && (
        <meta property="article:modified_time" content={article.modifiedTime.toISOString()} />
      )}
      {article.tags?.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}
    </>
  )}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content={`@${X_USERNAME}`} />
  <meta name="twitter:creator" content={`@${X_USERNAME}`} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />
  <meta name="twitter:image:alt" content={imageAlt} />

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <!-- Cloudflare Web Analytics -->
  <script
    is:inline
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon='{"token": "e31c135e4b43480c96db496537782204"}'
  ></script>
  <!-- End Cloudflare Web Analytics -->
</head>
<body>
  <header>
    <nav>
      <a href="/" class="brand">skyphusion.net</a>
      <span class="nav-links">
        <a href="/projects/">projects</a>
        <a href="/blog/">blog</a>
        <a href="/about/">about</a>
      </span>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p class="footer-identity">
      <a href="https://skyphusion.org">Skyphusion Labs</a>
      <span class="sep">/</span>
      <a href="https://github.skyphusion.org">Labs on GitHub</a>
      <span class="sep">/</span>
      <a href="https://github.com/skyphusion">Conrad Rockenhaus</a>
      <span class="sep">/</span>
      <a href="https://github.skyphusion.net">github.skyphusion.net</a>
      <span class="sep">/</span>
      <a href="https://vivijure.com">vivijure.com</a>
      <span class="sep">/</span>
      <a href="https://vivijure.skyphusion.org/welcome">Vivijure welcome</a>
      <span class="sep">/</span>
      <a href="https://x.com/skyphusion">@skyphusion</a>
    </p>
    <p>&copy; {new Date().getFullYear()} Conrad Rockenhaus <span class="sep">/</span> <a href="/rss.xml">RSS</a> <span class="sep">/</span> <a href="mailto:conrad@skyphusion.org">conrad@skyphusion.org</a></p>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --bg: #0f0f10;
    --fg: #e8e8e8;
    --muted: #8a8a8a;
    --accent: #6db4ff;
    --border: #2a2a2c;
    --code-bg: #1a1a1c;
  }

  *, *::before, *::after { box-sizing: border-box; }

  html, body {
    background: var(--bg);
    color: var(--fg);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
    line-height: 1.6;
    margin: 0;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  header {
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 1rem;
  }

  nav .brand {
    font-weight: 600;
    color: var(--fg);
    text-decoration: none;
  }

  nav .brand:hover { color: var(--accent); }

  nav .nav-links a {
    color: var(--muted);
    text-decoration: none;
    margin-left: 1.25rem;
  }

  nav .nav-links a:hover { color: var(--accent); }

  main { min-height: 60vh; }

  a {
    color: var(--accent);
    text-decoration: none;
  }
  a:hover { text-decoration: underline; }

  footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding-top: 1rem;
    color: var(--muted);
    font-size: 0.875rem;
  }
  footer .sep { color: var(--border); margin: 0 0.5rem; }
  footer .footer-identity {
    margin: 0 0 0.75rem 0;
    font-size: 0.8125rem;
  }

  h1, h2, h3, h4 { line-height: 1.25; }
  h1 { font-size: 1.875rem; margin-top: 0; }
  h2 { font-size: 1.375rem; margin-top: 2rem; }
  h3 { font-size: 1.125rem; }

  p { margin: 1rem 0; }

  code {
    background: var(--code-bg);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    font-size: 0.875em;
    border: 1px solid var(--border);
  }
  pre {
    background: var(--code-bg);
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    border: 1px solid var(--border);
  }
  pre code {
    background: transparent;
    padding: 0;
    border: none;
  }

  blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    color: var(--muted);
    margin: 1.25rem 0 1.25rem 0;
    font-style: italic;
  }

  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
  }
  th, td {
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  th { background: var(--code-bg); }

  img { max-width: 100%; height: auto; }
</style>
