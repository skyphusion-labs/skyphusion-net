{
	"compatibility_date": "2026-05-13",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "skyphusion-net",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
		"routes": [
			{ "pattern": "skyphusion.net", "custom_domain": true },
			{ "pattern": "www.skyphusion.net", "custom_domain": true }
		]
}
